<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox spacing="15.0" styleClass="content-area" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.minden.ui.controller.PlayersController">
    <!-- Ліва частина: Таблиця -->
    <VBox spacing="15.0" HBox.hgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <Label text="Управління гравцями" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="searchField" promptText="Пошук за іменем/email..." styleClass="input-field" prefWidth="220" />
            <Button text="Оновити" onAction="#handleRefresh" styleClass="action-button"/>
        </HBox>
        
        <TableView fx:id="playersTable" VBox.vgrow="ALWAYS" styleClass="data-table">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="40" />
                <TableColumn fx:id="usernameColumn" text="Ім'я" prefWidth="120" />
                <TableColumn fx:id="emailColumn" text="Email" prefWidth="160" />
                <TableColumn fx:id="goldColumn" text="Золото" prefWidth="80" />
                <TableColumn fx:id="energyColumn" text="Енергія" prefWidth="80" />
            </columns>
        </TableView>
    </VBox>

    <!-- Права частина: Панель редагування -->
    <VBox fx:id="editPanel" spacing="10.0" prefWidth="300" styleClass="login-box" visible="false">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
        </padding>
        <Label fx:id="editTitleLabel" text="Редагування" styleClass="section-title"/>
        
        <VBox spacing="5.0">
            <Label text="Username"/>
            <TextField fx:id="usernameField" styleClass="input-field"/>
        </VBox>
        
        <VBox spacing="5.0">
            <Label text="Email"/>
            <TextField fx:id="emailField" styleClass="input-field"/>
        </VBox>
        
        <HBox spacing="10.0">
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                <Label text="Gold"/>
                <TextField fx:id="goldField" styleClass="input-field"/>
            </VBox>
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                <Label text="Energy"/>
                <TextField fx:id="energyField" styleClass="input-field"/>
            </VBox>
        </HBox>

        <HBox spacing="10.0">
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                <Label text="X Coord"/>
                <TextField fx:id="xField" styleClass="input-field"/>
            </VBox>
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                <Label text="Y Coord"/>
                <TextField fx:id="yField" styleClass="input-field"/>
            </VBox>
        </HBox>

        <Region VBox.vgrow="ALWAYS" />
        
        <Button text="Зберегти зміни" onAction="#handleSave" styleClass="primary-button" maxWidth="Infinity"/>
        <Button text="Видалити гравця" onAction="#handleDelete" styleClass="logout-button" maxWidth="Infinity"/>
    </VBox>
</HBox>
