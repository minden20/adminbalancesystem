<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox spacing="15.0" styleClass="content-area" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.minden.ui.controller.EventController">
    <!-- Ліва частина: Таблиця -->
    <VBox spacing="15.0" HBox.hgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="Управління подіями" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Додати подію" onAction="#handleAdd" styleClass="primary-button"/>
            <Button text="Оновити" onAction="#handleRefresh" styleClass="action-button"/>
        </HBox>

        <TableView fx:id="eventsTable" VBox.vgrow="ALWAYS" styleClass="data-table">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="40" />
                <TableColumn fx:id="nameColumn" text="Назва" prefWidth="120" />
                <TableColumn fx:id="descriptionColumn" text="Опис" prefWidth="200" />
                <TableColumn fx:id="minGoldPenaltyColumn" text="Мін. штраф" prefWidth="90" />
                <TableColumn fx:id="maxGoldPenaltyColumn" text="Макс. штраф" prefWidth="90" />
            </columns>
        </TableView>
    </VBox>

    <!-- Права частина: Панель редагування -->
    <VBox fx:id="editPanel" spacing="10.0" prefWidth="300" styleClass="login-box" visible="false">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
        </padding>
        <Label fx:id="editTitleLabel" text="Редагування події" styleClass="section-title"/>

        <VBox spacing="5.0">
            <Label text="Назва"/>
            <TextField fx:id="nameField" styleClass="input-field"/>
        </VBox>

        <VBox spacing="5.0">
            <Label text="Опис"/>
            <TextField fx:id="descriptionField" styleClass="input-field"/>
        </VBox>

        <HBox spacing="10.0">
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                <Label text="Мін. штраф золота"/>
                <TextField fx:id="minGoldPenaltyField" styleClass="input-field"/>
            </VBox>
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                <Label text="Макс. штраф золота"/>
                <TextField fx:id="maxGoldPenaltyField" styleClass="input-field"/>
            </VBox>
        </HBox>

        <Region VBox.vgrow="ALWAYS" />

        <Button text="Зберегти зміни" onAction="#handleSave" styleClass="primary-button" maxWidth="Infinity"/>
        <Button text="Видалити подію" onAction="#handleDelete" styleClass="logout-button" maxWidth="Infinity"/>
    </VBox>
</HBox>