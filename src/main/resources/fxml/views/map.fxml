<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10.0" styleClass="content-area" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.minden.ui.controller.MapController">
    <Label text="Ігрова Карта (100x100)" styleClass="section-title">
        <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
        </padding>
    </Label>
    
    <ScrollPane fx:id="scrollPane" VBox.vgrow="ALWAYS" styleClass="data-table" fitToWidth="false" fitToHeight="false" pannable="true">
        <Canvas fx:id="mapCanvas" />
    </ScrollPane>
</VBox>
